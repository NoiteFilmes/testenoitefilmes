<!-- LOGIN MODAL - OCULTO POR PADRÃO (class="active" é adicionado via JS quando necessário) -->
<div class="login-modal" id="loginModal">
    <div class="login-box">
        <h2><i class="fas fa-film"></i> NoiteFilmes</h2>
        <div id="loginForm">
            <input type="email" id="loginEmail" placeholder="Email">
            <input type="password" id="loginPassword" placeholder="Senha">
            <button id="doLogin">Entrar</button>
            <div class="switch" id="showRegister">✨ Não tem conta? Cadastre-se</div>
        </div>
        <div id="registerForm" style="display:none;">
            <input type="email" id="registerEmail" placeholder="Email">
            <input type="password" id="registerPassword" placeholder="Senha">
            <input type="text" id="registerNickname" placeholder="@Nickname">
            <button id="doRegister">Cadastrar</button>
            <div class="switch" id="showLogin">← Voltar para o login</div>
        </div>
        <div class="register-hint">🎬 Entre e compartilhe sua paixão por filmes!</div>
    </div>
</div>

<script>
    // =====================================================
    // FIREBASE CONFIG
    // =====================================================
    const firebaseConfig = {
        apiKey: "AIzaSyAXQ_3yaVR6TgsAha6nU7uihHdd8NvrP78",
        authDomain: "noitefilmes26.firebaseapp.com",
        projectId: "noitefilmes26",
        storageBucket: "noitefilmes26.firebasestorage.app",
        messagingSenderId: "654439850210",
        appId: "1:654439850210:web:6f00af60cde262aafcbebb"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();
    const auth = firebase.auth();
    const storage = firebase.storage();

    // =====================================================
    // ESTADO GLOBAL
    // =====================================================
    let currentUser = null;
    let currentUsername = localStorage.getItem('noitefilmes_username') || 'Cinéfilo';
    let filmes = [];
    let series = [];
    let canais = [];
    let favoritos = [];
    let currentMedia = null;
    let currentMediaType = 'filme';
    let currentTab = 'filmes';
    let currentView = 'grid';
    let selectedSerie = null;
    let selectedTemporada = null;
    let selectedEpisode = null;
    let ytPlayer = null;
    let currentChat = 'geral';
    let currentChatUser = null;
    let currentChatUserName = 'Geral';
    let chatUnsubscribe = null;
    let isAdminLogged = false;
    let currentProfileTab = 'posts';
    let currentViewingUserId = null;
    let userProfileData = { displayName: '', bio: '', externalLink: '', avatarUrl: '' };
    const DEFAULT_AVATAR = 'https://i.ibb.co/Wps2rDCZ/C384-BA2-C-C5-BD-495-C-88-B8-00-C345-BE829-E.png';

    // DOM refs
    const mainEl = document.getElementById('mainContent');
    const topLinks = document.querySelectorAll('#topLinks a');
    const bottomItems = document.querySelectorAll('.bottom-item');
    const playerOverlay = document.getElementById('playerOverlay');
    const closePlayerBtn = document.getElementById('closePlayer');
    const loginModal = document.getElementById('loginModal');
    const userIndicator = document.getElementById('userIndicator');

    // =====================================================
    // FUNÇÕES DE LOGIN - CORRIGIDAS
    // =====================================================
    function showLoginModal() { 
        loginModal.classList.add('active'); 
    }
    function hideLoginModal() { 
        loginModal.classList.remove('active'); 
    }

    // =====================================================
    // FUNÇÕES AUXILIARES
    // =====================================================
    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function showToast(msg) {
        const existing = document.querySelector('.toast');
        if (existing) existing.remove();
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    function getAvatarUrl(avatarUrl) {
        return (avatarUrl && avatarUrl.trim()) ? avatarUrl : DEFAULT_AVATAR;
    }

    function formatTimeAgo(timestamp) {
        if (!timestamp) return 'agora';
        const diff = Date.now() - timestamp;
        const mins = Math.floor(diff / 60000);
        if (mins < 1) return 'agora';
        if (mins < 60) return `${mins} min`;
        const hrs = Math.floor(mins / 60);
        if (hrs < 24) return `${hrs} h`;
        const days = Math.floor(hrs / 24);
        if (days === 1) return 'ontem';
        return `${days} dias`;
    }

    function generateId() { return Date.now() + '-' + Math.random().toString(36).substring(2, 10); }

    function extractYoutubeId(url) {
        if (!url) return null;
        const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
        return match ? match[1] : null;
    }

    function isIptvLink(url) {
        if (!url) return false;
        return url.includes('.m3u8') || url.includes('.m3u') || url.includes('.mp4') || url.includes('playlist') || url.includes('m3u8?');
    }

    function makeNicknamesClickable(text) {
        if (!text) return text;
        return text.replace(/@([a-zA-Z0-9_]+)/g, (m, n) => `<span class="clickable-nick" data-nick="${n}">${m}</span>`);
    }

    function setupNicknameClicks() {
        document.querySelectorAll('.clickable-nick').forEach(el => {
            el.onclick = () => {
                const nick = el.getAttribute('data-nick');
                if (nick) findUserByNickname(nick);
            };
        });
    }

    function findUserByNickname(nickname) {
        db.ref('usuarios').orderByChild('nickname').equalTo(nickname).once('value', snap => {
            const data = snap.val();
            if (data) {
                const uid = Object.keys(data)[0];
                if (uid && currentUser && uid !== currentUser.uid) {
                    renderProfile(uid);
                    switchTab('perfil');
                } else if (uid && currentUser && uid === currentUser.uid) {
                    renderProfile();
                    switchTab('perfil');
                } else {
                    showToast(`Usuário @${nickname} não encontrado`);
                }
            } else {
                showToast(`Usuário @${nickname} não encontrado`);
            }
        });
    }

    // =====================================================
    // LOGIN / AUTH - EVENTOS
    // =====================================================
    document.getElementById('doLogin').onclick = () => {
        const email = document.getElementById('loginEmail').value;
        const pass = document.getElementById('loginPassword').value;
        auth.signInWithEmailAndPassword(email, pass).catch(e => showToast('Erro: ' + e.message));
    };

    document.getElementById('doRegister').onclick = () => {
        const email = document.getElementById('registerEmail').value;
        const pass = document.getElementById('registerPassword').value;
        let nick = document.getElementById('registerNickname').value.trim();
        if (nick.startsWith('@')) nick = nick.substring(1);
        if (!nick) { showToast('Digite um @nickname'); return; }
        auth.createUserWithEmailAndPassword(email, pass)
            .then(cred => {
                return db.ref(`usuarios/${cred.user.uid}`).set({ email, nickname: nick, createdAt: Date.now() });
            })
            .then(() => {
                currentUsername = nick;
                localStorage.setItem('noitefilmes_username', nick);
                showToast(`✅ Cadastro realizado! @${nick}`);
            })
            .catch(e => showToast('Erro: ' + e.message));
    };

    document.getElementById('showRegister').onclick = () => {
        document.getElementById('loginForm').style.display = 'none';
        document.getElementById('registerForm').style.display = 'block';
    };
    document.getElementById('showLogin').onclick = () => {
        document.getElementById('registerForm').style.display = 'none';
        document.getElementById('loginForm').style.display = 'block';
    };

    // =====================================================
    // AUTH STATE - CORRIGIDO
    // =====================================================
    auth.onAuthStateChanged(user => {
        currentUser = user;
        if (user) {
            hideLoginModal(); // ← OCULTA O MODAL QUANDO LOGADO
            userIndicator.innerHTML = `🟢 ${currentUsername}`;
            loadUserNickname(user.uid);
            loadFavoritos(user.uid);
            loadChatList();
            renderProfile();
            renderFeed();
            updateLastSeen();
            db.ref(`usuarios/${user.uid}`).once('value', snap => {
                const data = snap.val();
                if (data) {
                    if (data.displayName) userProfileData.displayName = data.displayName;
                    if (data.bio) userProfileData.bio = data.bio;
                    if (data.externalLink) userProfileData.externalLink = data.externalLink;
                    userProfileData.avatarUrl = getAvatarUrl(data.avatarUrl);
                }
            });
        } else {
            showLoginModal(); // ← MOSTRA O MODAL QUANDO DESLOGADO
            userIndicator.innerHTML = '🔴 Offline';
            currentUsername = 'Cinéfilo';
        }
    });

    function loadUserNickname(uid) {
        db.ref(`usuarios/${uid}/nickname`).once('value', snap => {
            if (snap.val()) {
                currentUsername = snap.val();
                localStorage.setItem('noitefilmes_username', currentUsername);
                userIndicator.innerHTML = `🟢 ${currentUsername}`;
            }
        });
    }

    function updateLastSeen() {
        if (currentUser) {
            db.ref(`usuarios/${currentUser.uid}/lastSeen`).set(Date.now());
        }
    }
    setInterval(updateLastSeen, 60000);

    function loadFavoritos(uid) {
        db.ref(`favoritos/${uid}`).on('value', snap => {
            favoritos = snap.val() ? Object.values(snap.val()) : [];
        });
    }

    // =====================================================
    // CARREGAR DADOS DO BANCO
    // =====================================================
    function loadFilmes() {
        db.ref('filmes').once('value', snap => {
            const data = snap.val();
            filmes = data ? Object.values(data).filter(i => i && !i.hidden) : [];
            updateContentCounters();
            if (currentTab === 'filmes') renderGrid();
            if (isAdminLogged) renderAdminList();
        });
    }

    function loadSeries() {
        db.ref('series').once('value', snap => {
            const data = snap.val();
            series = data ? Object.values(data).filter(i => i && !i.hidden) : [];
            updateContentCounters();
            if (currentTab === 'series') renderGrid();
            if (isAdminLogged) renderAdminList();
        });
    }

    function loadCanais() {
        db.ref('canais').once('value', snap => {
            const data = snap.val();
            canais = data ? Object.values(data).filter(i => i && !i.hidden) : [];
            updateContentCounters();
            if (currentTab === 'canais') renderGrid();
            if (isAdminLogged) renderAdminList();
        });
    }

    function updateContentCounters() {
        topLinks.forEach(link => {
            const tab = link.getAttribute('data-tab');
            if (tab === 'filmes') link.innerHTML = `<i class="fas fa-clapperboard"></i> Filmes <span class="badge">${filmes.length}</span>`;
            else if (tab === 'series') link.innerHTML = `<i class="fas fa-tv"></i> Séries <span class="badge">${series.length}</span>`;
            else if (tab === 'canais') link.innerHTML = `<i class="fas fa-satellite-dish"></i> Canais <span class="badge">${canais.length}</span>`;
        });
    }

    // =====================================================
    // RENDER GRID (Filmes / Séries / Canais)
    // =====================================================
    function renderGrid() {
        let items = [];
        let type = 'filme';
        if (currentTab === 'filmes') { items = filmes; type = 'filme'; }
        else if (currentTab === 'series') { items = series; type = 'serie'; }
        else if (currentTab === 'canais') { items = canais; type = 'canal'; }

        if (items.length === 0) {
            mainEl.innerHTML = `<div style="color:rgba(255,255,255,0.3); text-align:center; padding:40px;">
                <i class="fas fa-inbox" style="font-size:2rem; display:block; margin-bottom:10px;"></i>
                Nenhum conteúdo disponível ainda.
            </div>`;
            return;
        }

        let html = `<div class="grid">`;
        items.forEach(item => {
            const isIptv = isIptvLink(item.link);
            const views = item.views || 0;
            const hasFranchise = item.franchise ? true : false;
            html += `
                <div class="card" data-id="${item.id}" data-type="${type}">
                    <div class="poster">
                        ${item.thumb ? `<img src="${item.thumb}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">` : ''}
                        <i class="fas fa-play-circle" style="${item.thumb ? 'display:none;' : ''}"></i>
                        ${hasFranchise ? `<div class="franchise-badge" data-franchise="${escapeHtml(item.franchise)}"><i class="fas fa-film"></i> ${escapeHtml(item.franchise)}</div>` : ''}
                    </div>
                    <h4>${escapeHtml(item.title)} ${isIptv ? '<span style="font-size:0.5rem; background:#e50914; padding:0 6px; border-radius:10px;">VIDEO</span>' : ''}</h4>
                    <p><i class="fas fa-eye" style="color:rgba(255,255,255,0.3);"></i> ${views}</p>
                    <p style="font-size:0.6rem; opacity:0.4;">${item.category || 'Geral'} ${item.year ? '• ' + item.year : ''}</p>
                </div>
            `;
        });
        html += `</div>`;
        mainEl.innerHTML = html;

        // Eventos dos cards
        document.querySelectorAll('.card').forEach(card => {
            card.addEventListener('click', () => {
                const id = card.getAttribute('data-id');
                const type = card.getAttribute('data-type');
                let item;
                if (type === 'filme') item = filmes.find(f => f.id === id);
                else if (type === 'serie') item = series.find(s => s.id === id);
                else item = canais.find(c => c.id === id);
                if (item) playMedia(item, type);
            });
        });

        // Eventos dos badges de franquia
        document.querySelectorAll('.franchise-badge').forEach(badge => {
            badge.addEventListener('click', (e) => {
                e.stopPropagation();
                const nome = badge.getAttribute('data-franchise');
                if (nome) showFranchise(nome);
            });
        });

        setupNicknameClicks();
    }

    // =====================================================
    // FRANQUIAS
    // =====================================================
    async function showFranchise(nome) {
        const filmesFranquia = filmes.filter(f => f.franchise === nome);
        if (filmesFranquia.length === 0) {
            showToast('Nenhum filme encontrado para esta franquia');
            return;
        }
        let html = `
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap;">
                <span class="back-link" onclick="renderGrid()"><i class="fas fa-arrow-left"></i> Voltar</span>
                <h2 class="section-title"><i class="fas fa-film" style="color:#e50914;"></i> ${escapeHtml(nome)}</h2>
                <span style="color:rgba(255,255,255,0.3); font-size:0.8rem;">${filmesFranquia.length} filmes</span>
            </div>
            <div class="grid">
        `;
        filmesFranquia.sort((a, b) => (a.franchise_order || 999) - (b.franchise_order || 999));
        filmesFranquia.forEach((item, idx) => {
            html += `
                <div class="card" data-id="${item.id}" data-type="filme">
                    <div class="poster">
                        ${item.thumb ? `<img src="${item.thumb}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">` : ''}
                        <i class="fas fa-play-circle" style="${item.thumb ? 'display:none;' : ''}"></i>
                        <div style="position:absolute; top:6px; left:6px; background:#e50914; border-radius:50%; width:24px; height:24px; display:flex; align-items:center; justify-content:center; font-size:0.6rem; font-weight:bold; color:#fff;">${idx + 1}</div>
                    </div>
                    <h4>${escapeHtml(item.title)}</h4>
                    <p>${item.year || ''}</p>
                </div>
            `;
        });
        html += `</div>`;
        mainEl.innerHTML = html;

        document.querySelectorAll('.card').forEach(card => {
            card.addEventListener('click', () => {
                const id = card.getAttribute('data-id');
                const item = filmes.find(f => f.id === id);
                if (item) playMedia(item, 'filme');
            });
        });
    }

    // =====================================================
    // PLAYER
    // =====================================================
    function playMedia(item, type) {
        currentMedia = item;
        currentMediaType = type;

        playerOverlay.classList.add('active');

        document.getElementById('playerTitle').textContent = item.title;
        document.getElementById('playerYear').textContent = item.year || '';
        document.getElementById('playerGenre').textContent = item.category || '';
        document.getElementById('playerViews').innerHTML = `<i class="fas fa-eye"></i> ${item.views || 0}`;

        incrementView(item.id);
        loadLikeCount(item.id);
        loadRatings(item.id);
        loadComments(item.id);
        setupPlayerButtons(item);

        const youtubeDiv = document.getElementById('youtubePlayer');
        const hlsVideo = document.getElementById('hlsPlayer');
        const loading = document.getElementById('playerLoading');

        youtubeDiv.style.display = 'none';
        hlsVideo.style.display = 'none';
        loading.style.display = 'flex';

        const videoId = extractYoutubeId(item.link);
        const isHls = isIptvLink(item.link);

        if (videoId) {
            youtubeDiv.style.display = 'block';
            loading.style.display = 'none';
            if (ytPlayer) {
                ytPlayer.loadVideoById(videoId);
                ytPlayer.playVideo();
            } else {
                ytPlayer = new YT.Player('youtubePlayer', {
                    videoId: videoId,
                    playerVars: { autoplay: 1, controls: 1, modestbranding: 1, rel: 0 },
                    events: {
                        onReady: () => { loading.style.display = 'none'; },
                        onError: () => { showToast('Erro ao carregar vídeo do YouTube'); }
                    }
                });
            }
        } else if (isHls) {
            hlsVideo.style.display = 'block';
            loading.style.display = 'none';
            if (Hls.isSupported()) {
                if (window.hlsInstance) window.hlsInstance.destroy();
                const hls = new Hls();
                hls.loadSource(item.link);
                hls.attachMedia(hlsVideo);
                hls.on(Hls.Events.MANIFEST_PARSED, () => hlsVideo.play());
                window.hlsInstance = hls;
            } else if (hlsVideo.canPlayType('application/vnd.apple.mpegurl')) {
                hlsVideo.src = item.link;
                hlsVideo.play();
            } else {
                showToast('Formato não suportado');
                loading.style.display = 'none';
            }
        } else {
            showToast('Link não suportado');
            loading.style.display = 'none';
        }
    }

    function closePlayer() {
        playerOverlay.classList.remove('active');
        if (ytPlayer) { ytPlayer.stopVideo(); }
        if (window.hlsInstance) { window.hlsInstance.destroy(); window.hlsInstance = null; }
        const hlsVideo = document.getElementById('hlsPlayer');
        if (hlsVideo) { hlsVideo.pause(); hlsVideo.src = ''; hlsVideo.load(); }
        document.getElementById('playerLoading').style.display = 'flex';
    }

    closePlayerBtn.addEventListener('click', closePlayer);
    playerOverlay.addEventListener('click', (e) => { if (e.target === playerOverlay) closePlayer(); });

    function incrementView(id) {
        db.ref(`visualizacoes/${id}`).transaction(v => (v || 0) + 1);
        if (currentMedia && currentMedia.id === id) {
            db.ref(`visualizacoes/${id}`).once('value', snap => {
                document.getElementById('playerViews').innerHTML = `<i class="fas fa-eye"></i> ${snap.val() || 0}`;
            });
        }
    }

    function loadLikeCount(id) {
        db.ref(`likes/${id}`).on('value', snap => {
            const data = snap.val();
            const count = data ? Object.keys(data).length : 0;
            document.getElementById('likeCount').textContent = count;
            const btn = document.getElementById('likeBtn');
            if (currentUser && data && data[currentUser.uid]) {
                btn.classList.add('liked');
                btn.querySelector('i').className = 'fas fa-heart';
            } else {
                btn.classList.remove('liked');
                btn.querySelector('i').className = 'far fa-heart';
            }
        });
    }

    function loadRatings(id) {
        db.ref(`avaliacoes/${id}`).once('value', snap => {
            const data = snap.val();
            const total = data ? data.totalVotos || 0 : 0;
            const soma = data ? data.soma || 0 : 0;
            const media = total > 0 ? (soma / total) : 0;
            const percent = total > 0 ? Math.round((media / 5) * 100) : 0;
            document.getElementById('ratingPercent').textContent = percent + '%';
            updateStars(percent);
        });
    }

    function updateStars(percent) {
        const stars = document.querySelectorAll('#ratingStars i');
        const filled = Math.round((percent / 100) * 5);
        stars.forEach((star, i) => {
            if (i < filled) { star.className = 'fas fa-star'; star.style.color = '#ffc107'; }
            else { star.className = 'far fa-star'; star.style.color = 'rgba(255,255,255,0.2)'; }
        });
    }

    function setupPlayerButtons(item) {
        const likeBtn = document.getElementById('likeBtn');
        const saveBtn = document.getElementById('saveBtn');
        const shareBtn = document.getElementById('shareBtn');
        const stars = document.querySelectorAll('#ratingStars i');

        likeBtn.onclick = () => {
            if (!currentUser) { showToast('Faça login para curtir'); return; }
            const ref = db.ref(`likes/${item.id}/${currentUser.uid}`);
            ref.once('value', snap => {
                if (snap.exists()) {
                    ref.remove();
                    showToast('❤️ Like removido');
                } else {
                    ref.set(true);
                    showToast('👍 Curtiu!');
                }
            });
        };

        saveBtn.onclick = () => {
            if (!currentUser) { showToast('Faça login para favoritar'); return; }
            const existing = favoritos.find(f => f.id === item.id);
            if (existing && existing.saved) {
                db.ref(`favoritos/${currentUser.uid}/${item.id}`).remove();
                showToast('Removido dos favoritos');
            } else {
                db.ref(`favoritos/${currentUser.uid}/${item.id}`).set({
                    id: item.id, title: item.title, thumb: item.thumb, type: currentMediaType, saved: true
                });
                showToast('⭐ Adicionado aos favoritos!');
            }
        };

        shareBtn.onclick = () => {
            const url = `${window.location.origin}${window.location.pathname}?mediaId=${item.id}&type=${currentMediaType}`;
            if (navigator.share) {
                navigator.share({ title: item.title, text: `🎬 ${item.title} - NoiteFilmes`, url }).catch(() => {});
            } else {
                navigator.clipboard.writeText(url).then(() => showToast('📋 Link copiado!'));
            }
        };

        stars.forEach(star => {
            star.onclick = () => {
                if (!currentUser) { showToast('Faça login para avaliar'); return; }
                const value = parseInt(star.getAttribute('data-value'));
                const ref = db.ref(`avaliacoes/${item.id}/${currentUser.uid}`);
                ref.once('value', snap => {
                    const old = snap.val() || 0;
                    if (old === value) { showToast(`Sua avaliação já é ${value}/5`); return; }
                    ref.set(value);
                    db.ref(`avaliacoes/${item.id}`).transaction(data => {
                        if (!data) return { totalVotos: 1, soma: value };
                        let { totalVotos, soma } = data;
                        if (old === 0) { totalVotos++; soma += value; }
                        else { soma = soma - old + value; }
                        return { totalVotos, soma };
                    }).then(() => {
                        showToast(`⭐ Avaliação ${value}/5 salva!`);
                        loadRatings(item.id);
                    });
                });
            };
            star.onmouseenter = function() {
                const val = parseInt(this.getAttribute('data-value'));
                stars.forEach((s, i) => {
                    if (i < val) { s.className = 'fas fa-star'; s.style.color = '#ffc107'; }
                    else { s.className = 'far fa-star'; s.style.color = 'rgba(255,255,255,0.2)'; }
                });
            };
            star.onmouseleave = () => {
                loadRatings(item.id);
            };
        });
    }

