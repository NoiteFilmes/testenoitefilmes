    function openChat(chatId, name, avatar, userId = null) {
        document.getElementById('chatSidebar').style.display = 'none';
        document.getElementById('chatMain').style.display = 'flex';
        document.getElementById('chatName').textContent = name;
        const avatarEl = document.getElementById('chatAvatar');
        if (avatar.startsWith('http') || avatar.includes('data:')) {
            avatarEl.innerHTML = `<img src="${avatar}" onerror="this.src='${DEFAULT_AVATAR}'" style="width:100%; height:100%; object-fit:cover;">`;
        } else {
            avatarEl.textContent = avatar;
            avatarEl.style.background = 'linear-gradient(135deg,#e50914,#b20710)';
        }

        currentChat = chatId;
        currentChatUser = userId;
        currentChatUserName = name;

        if (chatUnsubscribe) { chatUnsubscribe(); chatUnsubscribe = null; }

        const messagesContainer = document.getElementById('chatMessages');
        messagesContainer.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Carregando...</div>';

        let ref;
        if (chatId === 'geral') {
            ref = db.ref('chat_messages');
        } else if (userId) {
            const key = `private_${[currentUser.uid, userId].sort().join('_')}`;
            ref = db.ref(`private_messages/${key}`);
        } else {
            return;
        }

        const onMessages = (snap) => {
            const data = snap.val();
            if (!data) {
                messagesContainer.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhuma mensagem ainda</div>';
                return;
            }
            const msgs = Object.entries(data).map(([id, m]) => ({ id, ...m })).sort((a, b) => (a.timestamp || 0) - (b.timestamp || 0));
            messagesContainer.innerHTML = msgs.map(m => {
                const isOwn = m.senderId === currentUser?.uid;
                return `<div class="msg ${isOwn ? 'sent' : 'received'}">
                    <div>${escapeHtml(m.text || '')}</div>
                    <span class="time">${formatTimeAgo(m.timestamp)}</span>
                </div>`;
            }).join('');
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            if (userId && userId !== currentUser?.uid) {
                const key = `private_${[currentUser.uid, userId].sort().join('_')}`;
                const unreadRef = db.ref(`private_messages/${key}`);
                unreadRef.once('value', snap => {
                    const msgs = snap.val();
                    if (msgs) {
                        for (const [id, m] of Object.entries(msgs)) {
                            if (m.senderId !== currentUser?.uid && m.status !== 'read') {
                                unreadRef.child(`${id}/status`).set('read');
                            }
                        }
                    }
                });
            }
        };

        ref.on('value', onMessages);
        chatUnsubscribe = () => ref.off('value', onMessages);
    }

    function sendChatMessage() {
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text || !currentUser) return;

        const msg = {
            text,
            senderId: currentUser.uid,
            senderName: currentUsername,
            timestamp: Date.now(),
            status: 'sent'
        };

        if (currentChat === 'geral') {
            db.ref('chat_messages').push(msg);
        } else if (currentChatUser) {
            const key = `private_${[currentUser.uid, currentChatUser].sort().join('_')}`;
            db.ref(`private_messages/${key}`).push(msg);
        }
        input.value = '';
        input.focus();
    }

