    function createPostModal() {
        const overlay = document.createElement('div');
        overlay.style.cssText = `
            position:fixed; inset:0; z-index:3000; background:rgba(0,0,0,0.9); backdrop-filter:blur(20px);
            display:flex; align-items:center; justify-content:center; padding:20px;
        `;
        overlay.innerHTML = `
            <div style="background:rgba(20,20,20,0.95); border-radius:32px; padding:24px; max-width:500px; width:100%; border:1px solid rgba(255,0,0,0.2);">
                <h3 style="color:#fff; margin-bottom:12px;"><i class="fas fa-plus-circle" style="color:#e50914;"></i> Nova Publicação</h3>
                <input type="file" id="postMediaInput" accept="image/*,video/*" style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:8px; color:#fff; margin-bottom:10px;">
                <div id="postPreview" style="border-radius:12px; overflow:hidden; margin-bottom:10px; display:none;"></div>
                <textarea id="postCaption" placeholder="Escreva uma legenda..." style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:8px; color:#fff; font-size:0.85rem; resize:vertical; min-height:60px;"></textarea>
                <div style="display:flex; gap:10px; margin-top:12px;">
                    <button id="cancelPost" style="flex:1; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:30px; padding:8px; color:rgba(255,255,255,0.6); cursor:pointer;">Cancelar</button>
                    <button id="submitPost" style="flex:1; background:#e50914; border:none; border-radius:30px; padding:8px; color:#fff; font-weight:600; cursor:pointer;">Publicar</button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);

        const fileInput = document.getElementById('postMediaInput');
        const preview = document.getElementById('postPreview');

        fileInput.addEventListener('change', () => {
            const file = fileInput.files[0];
            if (!file) { preview.style.display = 'none'; return; }
            preview.style.display = 'block';
            if (file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = (e) => { preview.innerHTML = `<img src="${e.target.result}" style="width:100%; max-height:300px; object-fit:contain;">`; };
                reader.readAsDataURL(file);
            } else if (file.type.startsWith('video/')) {
                const reader = new FileReader();
                reader.onload = (e) => { preview.innerHTML = `<video src="${e.target.result}" controls style="width:100%; max-height:300px;"></video>`; };
                reader.readAsDataURL(file);
            }
        });

        document.getElementById('cancelPost').onclick = () => overlay.remove();
        document.getElementById('submitPost').onclick = () => {
            const file = fileInput.files[0];
            const caption = document.getElementById('postCaption').value.trim();
            if (!file) { showToast('Selecione uma imagem ou vídeo'); return; }
            if (!currentUser) { showToast('Faça login para postar'); return; }

            const formData = new FormData();
            formData.append('file', file);
            formData.append('upload_preset', 'noitefilmes_unsigned');

            const isVideo = file.type.startsWith('video/');
            const cloudinaryUrl = `https://api.cloudinary.com/v1_1/dama2etyy/${isVideo ? 'video' : 'image'}/upload`;

            showToast('📤 Enviando...');
            fetch(cloudinaryUrl, { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    const postData = {
                        id: generateId(),
                        userId: currentUser.uid,
                        userName: currentUsername,
                        avatarUrl: userProfileData.avatarUrl || '',
                        mediaUrl: data.secure_url,
                        mediaType: isVideo ? 'video' : 'image',
                        caption: caption,
                        createdAt: Date.now(),
                        likesCount: 0,
                        comments: {}
                    };
                    return db.ref(`feed_posts/${postData.id}`).set(postData);
                })
                .then(() => {
                    showToast('✅ Publicado!');
                    overlay.remove();
                    renderFeed();
                })
                .catch(e => showToast('❌ Erro: ' + e.message));
        };
    }

