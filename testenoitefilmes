            const followersCount = followersSnap.val() ? Object.keys(followersSnap.val()).length : 0;
            const followingCount = followingSnap.val() ? Object.keys(followingSnap.val()).length : 0;

            let isFollowing = false;
            if (!isOwn && currentUser) {
                const check = await db.ref(`followers/${targetUserId}/${currentUser.uid}`).once('value');
