    function loadProfileTab(userId, tab) {
        const container = document.getElementById('profileTabContent');
        if (!container) return;

        if (tab === 'posts') {
            db.ref('feed_posts').orderByChild('userId').equalTo(userId).once('value', snap => {
                const data = snap.val();
                const posts = data ? Object.values(data).filter(p => !p.originalPostId).sort((a, b) => b.createdAt - a.createdAt) : [];
                if (posts.length === 0) {
                    container.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhuma publicação</div>';
                    return;
                }
                container.innerHTML = `<div class="profile-posts">${posts.map(p => `
                    <div class="post-item" onclick="viewPost('${p.id}')">
                        ${p.mediaType === 'video' ? 
                            `<video src="${p.mediaUrl}" style="width:100%; height:100%; object-fit:cover;"></video>` :
                            `<img src="${p.mediaUrl}" onerror="this.src='${DEFAULT_AVATAR}'">`
                        }
                    </div>
                `).join('')}</div>`;
            });
        } else if (tab === 'favoritos') {
            db.ref(`favoritos/${userId}`).once('value', snap => {
                const data = snap.val();
                const favs = data ? Object.values(data) : [];
                if (favs.length === 0) {
                    container.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhum favorito</div>';
                    return;
                }
                container.innerHTML = `<div class="profile-posts">${favs.map(f => `
                    <div class="post-item" onclick="playMediaById('${f.id}', '${f.type || 'filme'}')">
                        <img src="${f.thumb || DEFAULT_AVATAR}" onerror="this.src='${DEFAULT_AVATAR}'">
                    </div>
                `).join('')}</div>`;
            });
        } else if (tab === 'salvos') {
            db.ref('feed_posts').once('value', snap => {
                const all = snap.val();
                if (!all) { container.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhum salvo</div>'; return; }
                const saved = Object.values(all).filter(p => p.saves && p.saves[userId]);
                if (saved.length === 0) {
                    container.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhum salvo</div>';
                    return;
                }
                container.innerHTML = `<div class="profile-posts">${saved.map(p => `
                    <div class="post-item" onclick="viewPost('${p.id}')">
                        ${p.mediaType === 'video' ? 
                            `<video src="${p.mediaUrl}" style="width:100%; height:100%; object-fit:cover;"></video>` :
                            `<img src="${p.mediaUrl}" onerror="this.src='${DEFAULT_AVATAR}'">`
                        }
                    </div>
                `).join('')}</div>`;
            });
        } else if (tab === 'assistidos') {
            db.ref(`watched_history/${userId}`).once('value', snap => {
                const data = snap.val();
                if (!data) { container.innerHTML = '<div style="color:rgba(255,255,255,0.3); text-align:center; padding:20px;">Nenhum assistido</div>'; return; }
                const list = Object.values(data).sort((a, b) => b.watchedAt - a.watchedAt);
                container.innerHTML = `<div class="profile-posts">${list.slice(0, 30).map(h => `
                    <div class="post-item" onclick="playMediaById('${h.mediaId}', '${h.mediaType || 'filme'}')">
                        <img src="${h.thumb || DEFAULT_AVATAR}" onerror="this.src='${DEFAULT_AVATAR}'">
                        <div style="position:absolute; bottom:0; left:0; height:3px; background:#e50914; width:${h.progress || 0}%;"></div>
                    </div>
                `).join('')}</div>`;
            });
        }
    }

    function viewPost(postId) {
        showToast('Visualizando publicação');
        switchTab('feed');
        setTimeout(() => {
            const el = document.querySelector(`#feedPosts [data-post-id="${postId}"]`);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300);
    }

    function playMediaById(id, type) {
        let item;
        if (type === 'filme') item = filmes.find(f => f.id === id);
        else if (type === 'serie') item = series.find(s => s.id === id);
        else item = canais.find(c => c.id === id);
        if (item) playMedia(item, type);
    }

