            <video id="hlsPlayer" controls style="display:none; width:100%; height:100%; background:#000;"></video>
            <div id="playerLoading" style="display:flex; align-items:center; justify-content:center; height:100%; color:rgba(255,255,255,0.3);">Carregando...</div>
