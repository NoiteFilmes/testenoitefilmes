</div>

<!-- PLAYER OVERLAY -->
<div class="player-overlay" id="playerOverlay">
    <div class="player-box">
        <button class="close-btn" id="closePlayer"><i class="fas fa-times"></i></button>
        <div class="player-wrapper" id="playerWrapper">
