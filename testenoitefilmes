        const activeTab = document.querySelector('.admin-tabs button.active')?.getAttribute('data-tab') || 'filmes';
        const typeMap = { filmes: 'filmes', series: 'series', canais: 'canais' };
        const type = typeMap[activeTab] || 'filmes';

        const data = {
            title, link, thumb: thumb || 'https://via.placeholder.com/300x450',
            category: category || 'Geral', year: year || new Date().getFullYear().toString(),
            description: desc || title, createdAt: Date.now()
        };

        const id = generateId();
        db.ref(`${type}/${id}`).set({ id, ...data }).then(() => {
            showToast('✅ Salvo com sucesso!');
            resetAdminForm();
            if (type === 'filmes') loadFilmes();
            else if (type === 'series') loadSeries();
            else loadCanais();
            renderAdminList(activeTab);
        }).catch(e => showToast('❌ Erro: ' + e.message));
    }

    function editAdminItem(id, type) {
        let items = [];
        if (type === 'filmes') items = filmes;
        else if (type === 'series') items = series;
        else items = canais;

        const item = items.find(i => i.id === id);
        if (!item) return;

        document.getElementById('adminTitle').value = item.title || '';
        document.getElementById('adminLink').value = item.link || '';
        document.getElementById('adminThumb').value = item.thumb || '';
        document.getElementById('adminCategory').value = item.category || '';
        document.getElementById('adminYear').value = item.year || '';
        document.getElementById('adminDesc').value = item.description || '';

        document.getElementById('adminSave').textContent = '✏️ Atualizar';
        document.getElementById('adminSave').dataset.editId = id;
        document.getElementById('adminSave').dataset.editType = type;
        document.getElementById('adminCancel').style.display = 'inline-block';
    }

    function resetAdminForm() {
        document.getElementById('adminTitle').value = '';
        document.getElementById('adminLink').value = '';
        document.getElementById('adminThumb').value = '';
        document.getElementById('adminCategory').value = '';
        document.getElementById('adminYear').value = '';
        document.getElementById('adminDesc').value = '';
        document.getElementById('adminSave').textContent = '💾 Salvar';
        delete document.getElementById('adminSave').dataset.editId;
        delete document.getElementById('adminSave').dataset.editType;
        document.getElementById('adminCancel').style.display = 'none';
    }

    function deleteAdminItem(id, type) {
        if (!confirm('Tem certeza que deseja excluir?')) return;
        db.ref(`${type}/${id}`).remove().then(() => {
            showToast('🗑️ Removido!');
            if (type === 'filmes') loadFilmes();
            else if (type === 'series') loadSeries();
            else loadCanais();
            const activeTab = document.querySelector('.admin-tabs button.active')?.getAttribute('data-tab') || 'filmes';
            renderAdminList(activeTab);
        });
    }

    function autoFillAdmin() {
        const link = document.getElementById('adminLink').value.trim();
        if (!link) { showToast('Cole um link primeiro'); return; }

        const videoId = extractYoutubeId(link);
        if (videoId) {
            fetch(`https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${videoId}&format=json`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('adminTitle').value = data.title || '';
                    document.getElementById('adminThumb').value = data.thumbnail_url || `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
                    showToast('✅ Dados preenchidos!');
                })
                .catch(() => showToast('❌ Não foi possível obter dados'));
        } else if (isIptvLink(link)) {
            const fileName = link.split('/').pop().split('.')[0].replace(/[_-]/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            document.getElementById('adminTitle').value = fileName || 'Vídeo';
            showToast('✅ Nome extraído do link');
        } else {
            showToast('Link não reconhecido');
        }
    }

    function viewUserProfile(uid) {
        renderProfile(uid);
        switchTab('perfil');
        document.querySelector('.admin-panel')?.scrollIntoView({ behavior: 'smooth' });
    }

    function deleteUser(uid) {
        if (!confirm('Excluir usuário permanentemente?')) return;
        db.ref(`usuarios/${uid}`).remove().then(() => {
            showToast('Usuário excluído');
            renderAdminList('usuarios');
        });
    }

    function markReportResolved(id) {
        db.ref(`reports/${id}/status`).set('resolved').then(() => {
            showToast('✅ Report resolvido');
            renderAdminList('reports');
        });
    }

    function deleteReport(id) {
        if (!confirm('Excluir este report?')) return;
        db.ref(`reports/${id}`).remove().then(() => {
            showToast('Report removido');
            renderAdminList('reports');
        });
    }

    // =====================================================
    // FOLLOWERS / FOLLOWING LISTS
    // =====================================================
    window.showFollowersList = function(userId) {
        if (!userId) return;
        db.ref(`followers/${userId}`).once('value', async snap => {
            const data = snap.val();
            if (!data) { showToast('Nenhum seguidor'); return; }
            const ids = Object.keys(data);
            if (ids.length === 0) { showToast('Nenhum seguidor'); return; }
            const users = await Promise.all(ids.map(uid => db.ref(`usuarios/${uid}`).once('value')));
            const list = users.map((s, i) => ({ uid: ids[i], ...s.val() })).filter(u => u);
            showUserList(list, 'Seguidores');
        });
    };

    window.showFollowingList = function(userId) {
        if (!userId) return;
        db.ref(`following/${userId}`).once('value', async snap => {
            const data = snap.val();
            if (!data) { showToast('Nenhum seguindo'); return; }
            const ids = Object.keys(data);
            if (ids.length === 0) { showToast('Nenhum seguindo'); return; }
            const users = await Promise.all(ids.map(uid => db.ref(`usuarios/${uid}`).once('value')));
            const list = users.map((s, i) => ({ uid: ids[i], ...s.val() })).filter(u => u);
            showUserList(list, 'Seguindo');
        });
    };

    function showUserList(users, title) {
        const overlay = document.createElement('div');
        overlay.style.cssText = `
            position:fixed; inset:0; z-index:4000; background:rgba(0,0,0,0.9); backdrop-filter:blur(20px);
            display:flex; align-items:center; justify-content:center; padding:20px;
        `;
        overlay.innerHTML = `
            <div style="background:rgba(20,20,20,0.95); border-radius:32px; padding:24px; max-width:400px; width:100%; max-height:80vh; overflow-y:auto; border:1px solid rgba(255,0,0,0.2);">
                <h3 style="color:#fff; margin-bottom:12px;">${title}</h3>
                ${users.map(u => `
                    <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.03); cursor:pointer;" onclick="this.closest('[style]').remove(); renderProfile('${u.uid}'); switchTab('perfil');">
                        <div style="width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#e50914,#b20710); display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:bold; color:#fff; overflow:hidden;">
                            <img src="${getAvatarUrl(u.avatarUrl)}" onerror="this.src='${DEFAULT_AVATAR}'" style="width:100%; height:100%; object-fit:cover;">
                        </div>
                        <div>
                            <div style="font-weight:600; font-size:0.85rem;">${escapeHtml(u.displayName || u.nickname || 'Usuário')}</div>
                            <div style="font-size:0.6rem; color:rgba(255,255,255,0.3);">@${escapeHtml(u.nickname || '')}</div>
                        </div>
                    </div>
                `).join('')}
                <button onclick="this.closest('[style]').remove()" style="margin-top:12px; width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:30px; padding:8px; color:rgba(255,255,255,0.6); cursor:pointer;">Fechar</button>
            </div>
        `;
        document.body.appendChild(overlay);
        overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });
    }

    // =====================================================
    // NAVEGAÇÃO
    // =====================================================
    function switchTab(tab) {
        currentTab = tab;
        topLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('data-tab') === tab);
        });
        bottomItems.forEach(item => {
            item.classList.toggle('active', item.getAttribute('data-bottom') === tab || 
                (tab === 'inicio' && item.getAttribute('data-bottom') === 'inicio'));
        });
        switch (tab) {
            case 'filmes': renderGrid(); break;
            case 'series': renderGrid(); break;
            case 'canais': renderGrid(); break;
            case 'buscar': renderSearch(); break;
            case 'feed': renderFeed(); break;
            case 'perfil': renderProfile(); break;
            case 'admin': renderAdmin(); break;
            default: renderGrid();
        }
    }

    topLinks.forEach(link => {
        link.addEventListener('click', () => {
            const tab = link.getAttribute('data-tab');
            if (tab === 'filmes' || tab === 'series' || tab === 'canais') {
                if (playerOverlay.classList.contains('active')) closePlayer();
            }
            switchTab(tab);
        });
    });

    bottomItems.forEach(item => {
        item.addEventListener('click', () => {
            const tab = item.getAttribute('data-bottom');
            if (tab === 'inicio') switchTab('filmes');
            else if (tab === 'feed') switchTab('feed');
            else if (tab === 'chat') {
                if (!currentUser) { showToast('Faça login para acessar o chat'); return; }
                switchTab('chat');
            } else if (tab === 'perfil') switchTab('perfil');
        });
    });

    // =====================================================
    // INICIALIZAÇÃO
    // =====================================================
    function init() {
        loadFilmes();
        loadSeries();
        loadCanais();
        switchTab('filmes');

        document.addEventListener('visibilitychange', () => {
            if (!document.hidden && currentUser) updateLastSeen();
        });

        const params = new URLSearchParams(window.location.search);
        const mediaId = params.get('mediaId');
        const type = params.get('type');
        if (mediaId && type) {
            setTimeout(() => {
                let item;
                if (type === 'filme') item = filmes.find(f => f.id === mediaId);
                else if (type === 'serie') item = series.find(s => s.id === mediaId);
                else item = canais.find(c => c.id === mediaId);
                if (item) {
                    switchTab('filmes');
                    setTimeout(() => playMedia(item, type), 500);
                }
            }, 1000);
        }

        console.log('🚀 NoiteFilmes carregado com sucesso!');
        console.log(`📊 ${filmes.length} filmes, ${series.length} séries, ${canais.length} canais`);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    window.reloadData = function() {
        loadFilmes();
        loadSeries();
        loadCanais();
        showToast('📊 Dados recarregados!');
    };

    window.playMedia = playMedia;
    window.closePlayer = closePlayer;
    window.renderProfile = renderProfile;
    window.switchTab = switchTab;
    window.viewPost = viewPost;
    window.playMediaById = playMediaById;
    window.showFollowersList = window.showFollowersList;
    window.showFollowingList = window.showFollowingList;
    window.viewUserProfile = viewUserProfile;
    window.deleteUser = deleteUser;
    window.markReportResolved = markReportResolved;
    window.deleteReport = deleteReport;
    window.editAdminItem = editAdminItem;
    window.deleteAdminItem = deleteAdminItem;
    window.renderAdminList = renderAdminList;
    window.showFranchise = showFranchise;
    window.reloadData = window.reloadData;

    console.log('✅ Todos os dados do banco integrados!');
    console.log('💡 Use @nome para mencionar usuários nos comentários e posts.');
    console.log('🎬 Clique em um card para assistir ao conteúdo.');
    console.log('👑 Admin: senha "admin123"');
</script>
</body>
