<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes" />
    <title>Noite Filmes · rede social</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Firebase -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-storage-compat.js"></script>
    <!-- YouTube API -->
    <script src="https://www.youtube.com/iframe_api"></script>
    <!-- HLS.js para IPTV -->
    <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.8/dist/hls.min.js"></script>
    <style>
        /* ===== ESTILOS GLOBAIS ===== */
        * { margin:0; padding:0; box-sizing:border-box; font-family: system-ui, 'Segoe UI', Roboto, sans-serif; }
        body {
            background: #0a0a0a;
            background-image: radial-gradient(circle at 20% 30%, #1a0a0a 0%, #000 90%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 12px;
            color: #ffffff;
        }
        body.light-mode { 
            background: radial-gradient(circle at 10% 20%, #e0e8f5, #c5d0e5);
            color: #1a1a1a; 
        }
        body.light-mode .app { background: rgba(255,255,255,0.6); backdrop-filter: blur(12px); border-color: rgba(0,0,0,0.08); }
        body.light-mode .card { background: rgba(255,255,255,0.7); border-color: rgba(0,0,0,0.1); color: #1a1a1a; }
        body.light-mode .top-menu { background: rgba(255,255,255,0.6); border-color: rgba(0,0,0,0.08); }
        body.light-mode .bottom-menu { background: rgba(255,255,255,0.6); border-color: rgba(0,0,0,0.08); }
        body.light-mode .top-links a { color: rgba(0,0,0,0.7); }
        body.light-mode .top-links a:hover { background: rgba(229,9,20,0.15); color: #000; }
        body.light-mode .bottom-item { color: rgba(0,0,0,0.6); }
        body.light-mode .bottom-item.active { background: rgba(229,9,20,0.15); color: #000; }

        .app {
            max-width: 1400px; width:100%; height:95vh; max-height:900px; min-height:700px;
            background: rgba(10,10,10,0.35);
            backdrop-filter: blur(12px) saturate(180%);
            -webkit-backdrop-filter: blur(12px) saturate(180%);
            border-radius: 48px 48px 32px 32px;
            box-shadow: 0 30px 50px rgba(0,0,0,0.8), 0 0 0 1px rgba(255,0,0,0.15);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid rgba(255,30,30,0.2);
            position: relative;
        }
        .app::before {
            content:''; position:absolute; inset:0;
            background: radial-gradient(circle at 30% 40%, rgba(255,20,20,0.08), transparent 70%),
                        radial-gradient(circle at 80% 70%, rgba(200,0,0,0.05), transparent 60%);
            backdrop-filter: blur(2px);
            pointer-events: none;
            z-index:0;
            border-radius:inherit;
            animation: liquidMove 12s infinite alternate ease-in-out;
        }
        @keyframes liquidMove {
            0% { background: radial-gradient(circle at 20% 30%, rgba(255,40,40,0.10), transparent 65%),
                        radial-gradient(circle at 80% 70%, rgba(180,0,0,0.04), transparent 55%);
                transform:scale(1) rotate(0deg); }
            50% { background: radial-gradient(circle at 70% 20%, rgba(255,60,60,0.12), transparent 70%),
                        radial-gradient(circle at 20% 80%, rgba(220,0,0,0.06), transparent 60%);
                transform:scale(1.02) rotate(0.5deg); }
            100% { background: radial-gradient(circle at 40% 70%, rgba(255,80,80,0.08), transparent 60%),
                        radial-gradient(circle at 10% 30%, rgba(200,0,0,0.10), transparent 50%);
                transform:scale(1) rotate(-0.3deg); }
        }

        /* ===== TOP MENU ===== */
        .top-menu {
            position:relative; z-index:10; padding:14px 22px 10px 22px;
            background:rgba(0,0,0,0.25); backdrop-filter:blur(10px);
            border-bottom:1px solid rgba(255,0,0,0.2);
            display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:10px;
            flex-shrink:0;
        }
        .brand {
            display:flex; align-items:center; gap:8px; color:#e50914; font-weight:700; font-size:1.3rem;
            text-shadow:0 0 12px rgba(229,9,20,0.4);
        }
        .brand i { font-size:1.6rem; filter:drop-shadow(0 0 6px #e50914); }
        .brand .user-indicator { font-size:0.7rem; color:rgba(255,255,255,0.5); font-weight:400; margin-left:8px; }
        body.light-mode .brand .user-indicator { color:rgba(0,0,0,0.5); }

        .top-links {
            display:flex; flex-wrap:wrap; align-items:center; gap:4px 12px; list-style:none; font-weight:500;
        }
        .top-links li { display:inline-block; }
        .top-links a {
            color:rgba(255,255,255,0.8); text-decoration:none; font-size:0.95rem; padding:6px 14px;
            border-radius:40px; transition:all 0.2s; background:transparent; border:1px solid transparent;
            cursor:pointer;
        }
        .top-links a:hover, .top-links a.active {
            background:rgba(229,9,20,0.25); color:#fff; border-color:rgba(229,9,20,0.5);
            box-shadow:0 0 20px rgba(229,9,20,0.2); transform:scale(1.02);
        }
        .top-links a i { margin-right:6px; font-size:0.8rem; opacity:0.7; }
        .top-links a .badge {
            background:#e50914; color:#fff; border-radius:50%; padding:0 6px; font-size:0.6rem;
            margin-left:4px;
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            flex:1; position:relative; z-index:5; padding:16px 24px 10px 24px;
            overflow-y:auto; display:flex; flex-direction:column; gap:16px;
        }
        .main-content::-webkit-scrollbar { width:4px; }
        .main-content::-webkit-scrollbar-thumb { background:#e50914; border-radius:12px; }

        /* ===== CARDS ===== */
        .grid {
            display:grid; grid-template-columns:repeat(auto-fill, minmax(150px,1fr)); gap:18px; margin-top:4px;
        }
        .card {
            background:rgba(20,20,20,0.35); backdrop-filter:blur(8px); border-radius:28px;
            padding:14px 10px 16px; border:1px solid rgba(255,255,255,0.05);
            box-shadow:0 8px 24px rgba(0,0,0,0.6); transition:all 0.25s;
            display:flex; flex-direction:column; align-items:center; text-align:center; color:#f0f0f0;
            cursor:pointer; position:relative;
        }
        .card:hover {
            transform:translateY(-6px) scale(1.01); border-color:rgba(229,9,20,0.6);
            background:rgba(30,30,30,0.5); box-shadow:0 12px 30px rgba(229,9,20,0.2);
        }
        .card .poster {
            width:100%; aspect-ratio:2/3; background:linear-gradient(145deg,#1e0a0a,#0f0f0f);
            border-radius:18px; display:flex; align-items:center; justify-content:center;
            font-size:2.4rem; color:#e50914; border:1px solid rgba(229,9,20,0.2);
            margin-bottom:10px; overflow:hidden; position:relative;
        }
        .card .poster img {
            width:100%; height:100%; object-fit:cover;
        }
        .card h4 { font-size:0.9rem; font-weight:600; margin-bottom:2px; color:#fff; }
        .card p { font-size:0.7rem; opacity:0.6; display:flex; align-items:center; gap:6px; }
        .card .franchise-badge {
            position:absolute; bottom:70px; left:50%; transform:translateX(-50%);
            background:rgba(0,0,0,0.7); backdrop-filter:blur(8px);
            border:1px solid rgba(229,9,20,0.3); border-radius:20px;
            padding:2px 10px; font-size:0.55rem; color:#fff; display:flex; align-items:center; gap:4px;
            white-space:nowrap; cursor:pointer; transition:all 0.2s;
        }
        .card .franchise-badge:hover {
            background:rgba(229,9,20,0.8); transform:translateX(-50%) scale(1.05);
        }

        /* ===== BOTTOM MENU ===== */
        .bottom-menu {
            position:relative; z-index:12; background:rgba(0,0,0,0.5);
            backdrop-filter:blur(20px) saturate(200%);
            border-top:1px solid rgba(255,0,0,0.2);
            padding:8px 12px 12px; display:flex; flex-wrap:wrap; align-items:center;
            justify-content:space-around; flex-shrink:0; gap:4px;
        }
        .bottom-item {
            display:flex; flex-direction:column; align-items:center; justify-content:center;
            color:rgba(255,255,255,0.65); text-decoration:none; font-size:0.7rem;
            padding:6px 14px; border-radius:40px; transition:all 0.2s; background:transparent;
            border:1px solid transparent; min-width:60px; gap:2px; cursor:pointer;
        }
        .bottom-item i { font-size:1.5rem; margin-bottom:2px; }
        .bottom-item.active { color:#fff; background:rgba(229,9,20,0.25); border-color:rgba(229,9,20,0.4); }
        .bottom-item.active i { color:#e50914; text-shadow:0 0 12px #e50914; }
        .bottom-item:hover { background:rgba(229,9,20,0.15); color:#fff; border-color:rgba(229,9,20,0.3); transform:translateY(-2px); }
        .bottom-item .badge {
            background:#e50914; color:#fff; border-radius:50%; padding:0 6px; font-size:0.5rem;
            position:absolute; top:0; right:-5px;
        }

        /* ===== BACK LINK ===== */
        .back-link {
            color:rgba(255,255,255,0.7); background:rgba(0,0,0,0.3); padding:6px 16px; border-radius:40px;
            border:1px solid rgba(255,0,0,0.15); cursor:pointer; display:inline-flex; align-items:center; gap:8px;
            font-size:0.8rem; transition:0.2s; backdrop-filter:blur(4px); width:fit-content;
        }
        .back-link:hover { background:rgba(229,9,20,0.2); color:#fff; border-color:#e50914; }
        .section-title { color:#fff; font-weight:500; letter-spacing:-0.3px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }

        /* ===== PLAYER OVERLAY ===== */
        .player-overlay {
            position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.85);
            backdrop-filter:blur(20px); display:none; align-items:center; justify-content:center;
            padding:20px;
        }
        .player-overlay.active { display:flex; }
        .player-box {
            background:rgba(20,20,20,0.9); border-radius:32px; max-width:900px; width:100%;
            max-height:90vh; overflow-y:auto; border:1px solid rgba(255,0,0,0.2);
            padding:20px; position:relative;
        }
        .player-box .close-btn {
            position:absolute; top:12px; right:16px; background:rgba(255,0,0,0.2);
            border:none; border-radius:50%; width:36px; height:36px; color:#fff;
            font-size:1.2rem; cursor:pointer; transition:0.2s; z-index:10;
        }
        .player-box .close-btn:hover { background:#e50914; transform:scale(1.1); }
        .player-wrapper { background:#000; border-radius:16px; overflow:hidden; aspect-ratio:16/9; }
        .player-wrapper iframe, .player-wrapper video { width:100%; height:100%; border:none; }
        .player-info { margin-top:12px; }
        .player-info h3 { font-size:1.1rem; color:#fff; }
        .player-info .meta { font-size:0.8rem; color:rgba(255,255,255,0.5); display:flex; gap:12px; flex-wrap:wrap; }
        .player-info .actions { display:flex; gap:10px; margin-top:8px; flex-wrap:wrap; }
        .player-info .actions button {
            background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1);
            border-radius:30px; padding:4px 14px; color:#fff; font-size:0.7rem;
            cursor:pointer; transition:0.2s; display:flex; align-items:center; gap:6px;
        }
        .player-info .actions button:hover { background:rgba(229,9,20,0.3); border-color:#e50914; }
        .player-info .actions button.liked { color:#e50914; }
        .rating-stars { display:flex; gap:2px; align-items:center; }
        .rating-stars i { cursor:pointer; font-size:1.2rem; color:rgba(255,255,255,0.2); transition:0.2s; }
        .rating-stars i.active { color:#ffc107; }
        .rating-stars i:hover { transform:scale(1.2); }

        /* ===== COMMENTS ===== */
        .comments-section { margin-top:12px; border-top:1px solid rgba(255,255,255,0.05); padding-top:12px; }
        .comments-section h4 { color:rgba(255,255,255,0.7); font-size:0.8rem; margin-bottom:8px; }
        .comment-item { display:flex; gap:8px; margin-bottom:6px; padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.03); }
        .comment-item .avatar { width:28px; height:28px; border-radius:50%; background:linear-gradient(135deg,#e50914,#b20710); display:flex; align-items:center; justify-content:center; font-size:0.6rem; font-weight:bold; color:#fff; flex-shrink:0; overflow:hidden; }
        .comment-item .avatar img { width:100%; height:100%; object-fit:cover; }
        .comment-item .content { flex:1; }
        .comment-item .content .user { font-size:0.7rem; font-weight:600; color:#e50914; }
        .comment-item .content .text { font-size:0.75rem; color:rgba(255,255,255,0.8); }
        .comment-item .content .time { font-size:0.55rem; color:rgba(255,255,255,0.3); }
        .comment-input { display:flex; gap:8px; margin-top:8px; }
        .comment-input input { flex:1; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:30px; padding:6px 14px; color:#fff; font-size:0.75rem; outline:none; }
        .comment-input button { background:#e50914; border:none; border-radius:30px; padding:6px 16px; color:#fff; font-size:0.7rem; cursor:pointer; transition:0.2s; }
        .comment-input button:hover { background:#b20710; }

        /* ===== SEARCH ===== */
        .search-box { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
        .search-box input { flex:1; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:30px; padding:8px 16px; color:#fff; font-size:0.85rem; outline:none; min-width:180px; }
        .search-box input::placeholder { color:rgba(255,255,255,0.3); }
        .search-filters { display:flex; gap:6px; flex-wrap:wrap; }
        .search-filters button { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:30px; padding:4px 14px; color:rgba(255,255,255,0.6); font-size:0.7rem; cursor:pointer; transition:0.2s; }
        .search-filters button.active { background:rgba(229,9,20,0.3); border-color:#e50914; color:#fff; }

        /* ===== PROFILE ===== */
        .profile-header { display:flex; align-items:center; gap:20px; flex-wrap:wrap; padding:10px 0; }
        .profile-avatar { width:80px; height:80px; border-radius:50%; background:linear-gradient(135deg,#e50914,#b20710); display:flex; align-items:center; justify-content:center; font-size:2rem; color:#fff; flex-shrink:0; overflow:hidden; position:relative; }
        .profile-avatar img { width:100%; height:100%; object-fit:cover; }
        .profile-info { flex:1; }
        .profile-info .name { font-size:1.2rem; font-weight:700; }
        .profile-info .nick { color:rgba(255,255,255,0.5); font-size:0.8rem; }
        .profile-info .bio { font-size:0.85rem; margin-top:4px; }
        .profile-stats { display:flex; gap:20px; margin-top:8px; }
        .profile-stats span { font-size:0.8rem; color:rgba(255,255,255,0.6); }
        .profile-stats span strong { color:#fff; }
        .profile-stats span .clickable { cursor:pointer; transition:0.2s; }
        .profile-stats span .clickable:hover { color:#e50914; }

        .profile-tabs { display:flex; gap:4px; border-bottom:1px solid rgba(255,255,255,0.05); margin-top:12px; }
        .profile-tabs button { background:transparent; border:none; padding:8px 16px; color:rgba(255,255,255,0.4); font-size:0.7rem; cursor:pointer; transition:0.2s; border-bottom:2px solid transparent; }
        .profile-tabs button.active { color:#fff; border-bottom-color:#e50914; }
        .profile-tabs button:hover { color:#fff; }
        .profile-posts { display:grid; grid-template-columns:repeat(3,1fr); gap:4px; margin-top:12px; }
        .profile-posts .post-item { aspect-ratio:1; background:rgba(255,255,255,0.05); border-radius:8px; overflow:hidden; cursor:pointer; position:relative; }
        .profile-posts .post-item img, .profile-posts .post-item video { width:100%; height:100%; object-fit:cover; }

        /* ===== CHAT ===== */
        .chat-container { display:flex; height:100%; gap:12px; }
        .chat-sidebar { width:280px; flex-shrink:0; background:rgba(0,0,0,0.2); border-radius:20px; padding:12px; overflow-y:auto; }
        .chat-sidebar h4 { color:rgba(255,255,255,0.7); font-size:0.8rem; margin-bottom:10px; }
        .chat-user-item { display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:12px; cursor:pointer; transition:0.2s; }
        .chat-user-item:hover { background:rgba(255,255,255,0.06); }
        .chat-user-item.active { background:rgba(229,9,20,0.2); }
        .chat-user-item .avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#e50914,#b20710); display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:bold; color:#fff; flex-shrink:0; overflow:hidden; }
        .chat-user-item .avatar img { width:100%; height:100%; object-fit:cover; }
        .chat-user-item .info { flex:1; min-width:0; }
        .chat-user-item .info .name { font-size:0.8rem; font-weight:600; }
        .chat-user-item .info .last { font-size:0.65rem; color:rgba(255,255,255,0.4); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .chat-user-item .unread { background:#e50914; border-radius:50%; padding:0 6px; font-size:0.6rem; color:#fff; }
        .chat-main { flex:1; display:flex; flex-direction:column; background:rgba(0,0,0,0.2); border-radius:20px; overflow:hidden; }
        .chat-main .header { padding:10px 16px; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:10px; }
        .chat-main .header .avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#e50914,#b20710); display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:bold; color:#fff; flex-shrink:0; overflow:hidden; }
        .chat-main .header .avatar img { width:100%; height:100%; object-fit:cover; }
        .chat-main .header .name { font-weight:600; font-size:0.9rem; }
        .chat-main .messages { flex:1; overflow-y:auto; padding:12px; display:flex; flex-direction:column; gap:6px; }
        .chat-main .messages .msg { max-width:75%; padding:8px 14px; border-radius:16px; font-size:0.8rem; word-break:break-word; }
        .chat-main .messages .msg.sent { align-self:flex-end; background:#e50914; color:#fff; border-bottom-right-radius:4px; }
        .chat-main .messages .msg.received { align-self:flex-start; background:rgba(255,255,255,0.08); color:#fff; border-bottom-left-radius:4px; }
        .chat-main .messages .msg .time { font-size:0.5rem; opacity:0.5; margin-top:2px; display:block; text-align:right; }
        .chat-main .input-area { display:flex; gap:8px; padding:10px 16px; border-top:1px solid rgba(255,255,255,0.05); }
        .chat-main .input-area input { flex:1; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); border-radius:30px; padding:8px 16px; color:#fff; font-size:0.8rem; outline:none; }
        .chat-main .input-area button { background:#e50914; border:none; border-radius:30px; padding:8px 16px; color:#fff; cursor:pointer; transition:0.2s; }
        .chat-main .input-area button:hover { background:#b20710; }

        /* ===== ADMIN ===== */
        .admin-panel { background:rgba(0,0,0,0.3); border-radius:20px; padding:16px; }
        .admin-panel .admin-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:12px; }
        .admin-panel .admin-tabs button { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:30px; padding:4px 14px; color:rgba(255,255,255,0.6); font-size:0.7rem; cursor:pointer; transition:0.2s; }
        .admin-panel .admin-tabs button.active { background:rgba(229,9,20,0.3); border-color:#e50914; color:#fff; }
        .admin-panel .admin-form { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
        .admin-panel .admin-form input, .admin-panel .admin-form textarea, .admin-panel .admin-form select {
            background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:12px;
            padding:6px 12px; color:#fff; font-size:0.75rem; outline:none;
        }
        .admin-panel .admin-form textarea { grid-column:1/-1; resize:vertical; min-height:60px; }
        .admin-panel .admin-form .full { grid-column:1/-1; }
        .admin-panel .admin-form button { background:#e50914; border:none; border-radius:30px; padding:6px 16px; color:#fff; cursor:pointer; transition:0.2s; font-size:0.75rem; }
        .admin-panel .admin-form button:hover { background:#b20710; }
        .admin-panel .admin-list { max-height:200px; overflow-y:auto; margin-top:10px; }
        .admin-panel .admin-list .item { display:flex; justify-content:space-between; align-items:center; padding:4px 8px; border-bottom:1px solid rgba(255,255,255,0.03); font-size:0.7rem; }
        .admin-panel .admin-list .item .actions button { background:transparent; border:none; color:rgba(255,255,255,0.4); cursor:pointer; font-size:0.7rem; padding:0 4px; }
        .admin-panel .admin-list .item .actions button:hover { color:#e50914; }

        /* ===== TOAST ===== */
        .toast {
            position:fixed; bottom:100px; left:50%; transform:translateX(-50%);
            background:rgba(0,0,0,0.9); backdrop-filter:blur(20px); color:#fff;
            padding:10px 24px; border-radius:60px; font-size:0.8rem; z-index:9999;
            border:1px solid rgba(255,255,255,0.1); animation:fadeToast 3s ease forwards;
        }
        @keyframes fadeToast {
            0% { opacity:0; transform:translateX(-50%) translateY(20px); }
            15% { opacity:1; transform:translateX(-50%) translateY(0); }
            85% { opacity:1; transform:translateX(-50%) translateY(0); }
            100% { opacity:0; transform:translateX(-50%) translateY(-10px); }
