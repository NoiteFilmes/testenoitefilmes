            let html = `
                <div class="profile-header">
                    <div class="profile-avatar">
                        <img src="${avatarUrl}" onerror="this.src='${DEFAULT_AVATAR}'">
                        ${isOwn ? `<div style="position:absolute; bottom:0; right:0; background:#e50914; border-radius:50%; width:24px; height:24px; display:flex; align-items:center; justify-content:center; cursor:pointer; border:2px solid #0a0a0a;" id="changeAvatarBtn"><i class="fas fa-camera" style="font-size:10px; color:#fff;"></i></div>` : ''}
                    </div>
                    <div class="profile-info">
                        <div class="name">${escapeHtml(displayName)}</div>
                        <div class="nick">@${escapeHtml(nickname)}</div>
                        <div class="bio">${makeNicknamesClickable(escapeHtml(bio))}</div>
                        ${externalLink ? `<a href="${externalLink}" target="_blank" style="color:#e50914; font-size:0.7rem; display:inline-block; margin-top:4px;"><i class="fas fa-link"></i> ${escapeHtml(externalLink)}</a>` : ''}
                        <div class="profile-stats">
                            <span><strong>${totalPosts}</strong> posts</span>
                            <span><strong class="clickable" onclick="showFollowersList('${targetUserId}')">${followersCount}</strong> seguidores</span>
                            <span><strong class="clickable" onclick="showFollowingList('${targetUserId}')">${followingCount}</strong> seguindo</span>
                        </div>
                        ${!isOwn ? `<button id="followBtn" style="background:${isFollowing ? '#363636' : '#e50914'}; border:none; border-radius:30px; padding:6px 20px; color:#fff; font-weight:600; cursor:pointer; margin-top:8px;">${isFollowing ? 'Seguindo' : 'Seguir'}</button>` : ''}
